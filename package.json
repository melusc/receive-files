{
	"name": "file-receiver",
	"packageManager": "pnpm@11.1.2",
	"private": true,
	"devDependencies": {
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2"
	},
	"scripts": {
		"fmt": "prettier -w . **/*.svelte && pnpm -r fmt",
		"build": "pnpm -r build",
		"start": "pnpm --filter server start",
		"dev": "pnpm -r dev",
		"clean": "pnpm -r clean"
	},
	"type": "module"
}
