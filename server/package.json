{
	"name": "server",
	"private": true,
	"type": "module",
	"engines": {
		"node": "^24.15.0"
	},
	"dependencies": {
		"@inquirer/confirm": "^6.0.12",
		"client": "workspace:^",
		"express": "^5.2.1",
		"get-port": "^7.2.0",
		"multer": "^2.1.1"
	},
	"devDependencies": {
		"@lusc/eslint-config": "^10.0.0",
		"@lusc/tsconfig": "^7.2.0",
		"@types/express": "^5.0.6",
		"@types/multer": "^2.1.0",
		"@types/node": "^24.12.2",
		"concurrently": "^9.2.1",
		"esbuild": "^0.28.0",
		"eslint": "^10.2.1",
		"rimraf": "^6.1.3",
		"typescript": "^6.0.3"
	},
	"scripts": {
		"build": "pnpm clean && pnpm tsc && pnpm esbuild",
		"build:w": "pnpm esbuild -- --watch",
		"esbuild": "esbuild --outdir=dist --format=esm --platform=node --bundle --sourcemap --packages=external src/server.ts",
		"start:w": "node --watch dist/server.js",
		"start": "node dist/server.js",
		"dev": "concurrently pnpm:build:w pnpm:start:w",
		"clean": "rimraf dist",
		"fmt": "eslint --fix"
	}
}
